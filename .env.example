# Helscoop Environment Variables
# Copy this file to .env and fill in the values

# ---- Database ----
DATABASE_URL=postgres://helscoop:helscoop_dev@localhost:5433/helscoop

# ---- API ----
PORT=3001
JWT_SECRET=change-me-in-production
NODE_ENV=development

# ---- Redis (optional, for rate limiting & caching) ----
REDIS_URL=redis://localhost:6379

# ---- Web ----
NEXT_PUBLIC_API_URL=http://localhost:3001

# ---- OAuth sign-in ----
# Google OAuth client ID. Use the same browser client ID in web and API token verification.
# GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Apple Services ID and redirect URI configured in Apple Developer.
# APPLE_CLIENT_ID=
# NEXT_PUBLIC_APPLE_CLIENT_ID=
# NEXT_PUBLIC_APPLE_REDIRECT_URI=http://localhost:3000

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# ---- Deployment (Fly.io) ----
# FLY_API_TOKEN=  # Set in GitHub Actions secrets, not here

# ---- Build metadata ----
# APP_VERSION=dev  # Set automatically by CI (git SHA); used in /health and /api/health responses

# ---- Email (Resend) ----
# RESEND_API_KEY=  # Transactional email (password reset, verification)
# EMAIL_FROM=noreply@helscoop.fi

# ---- External APIs (optional) ----
# OPENAI_API_KEY=  # For AI chat assistant
# BUILDING_REGISTRY_ENABLED=false  # Set true, or configure DVV_API_KEY, to call Finnish registry APIs after demo-data miss
# BUILDING_REGISTRY_TIMEOUT_MS=2500
# DVV_API_KEY=  # Optional registry API key; sent as Bearer and X-API-Key when configured
# DVV_BUILDING_API_URL=https://paikkatiedot.ymparisto.fi/geoserver/ryhti_building/ogc/features/v1
# MML_API_KEY=  # Optional for authenticated MML endpoints when enabled by deployment
# FMI_LOOKUP_ENABLED=true
# FMI_WFS_URL=https://opendata.fmi.fi/wfs

# ---- Sentry error tracking ----
# SENTRY_DSN=                # API server-side DSN (use EU data region: o<N>.ingest.de.sentry.io)
# NEXT_PUBLIC_SENTRY_DSN=    # Web client-side DSN (same project, or separate browser project)
# SENTRY_AUTH_TOKEN=         # CI token for source map upload (create in Sentry → Settings → Auth tokens)
# SENTRY_ORG=helscoop        # Sentry organization slug
# SENTRY_PROJECT=helscoop-web # Sentry project slug (web frontend)
